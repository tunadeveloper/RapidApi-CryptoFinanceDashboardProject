@using X.PagedList
@model IPagedList<RapidApi_CryptoFinanceDashboardProject.Models.ListingDelistingItem>
@{
    ViewData["Title"] = "Liste Giriş / Çıkışlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex-1 overflow-y-auto p-8 space-y-8">
    <div class="mx-auto max-w-7xl space-y-8">

        <div class="space-y-4">
            <div class="flex items-center justify-between px-1">
                <h2 class="text-lg font-bold text-slate-900">Liste Giriş / Çıkışlar</h2>
                <a class="text-sm font-semibold text-primary hover:text-primary/80 flex items-center gap-1" href="#">
                    Tümünü Gör
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var item in Model)
                    {
                        <div class="rounded-3xl bg-white p-5 shadow-soft border border-slate-100 hover:border-primary/20 transition-all cursor-pointer">
                            <div class="flex items-center justify-between gap-2 mb-3">
                            <span class="px-2.5 py-1 rounded-lg text-xs font-bold @(item.category == "listing" ? "bg-green-50 text-green-800 border border-green-100" : "bg-amber-50 text-amber-800 border border-amber-100")">
                                @(item.category == "listing" ? "Listeleme" : "Listeden Çıkarma")
                                </span>
                                    <span class="text-xs font-semibold text-text-muted uppercase">@item.symbol</span>
                            </div>
                        <p class="text-xs font-medium text-text-muted">@item.published_date.ToString("dd-MMMM yyyy")</p>
                            <p class="font-bold text-slate-900 mt-2 line-clamp-2">@(item.title ?? "—")</p>
                                <p class="text-sm text-slate-600 mt-2 line-clamp-3">@item.content</p>
                                <p class="text-xs font-medium text-text-muted mt-3">@item.source</p>
                        </div>
                    }
                </div>
            <div class="flex items-center justify-between border-t border-slate-100 px-8 py-5 bg-slate-50/50">
                <p class="text-sm font-medium text-text-muted">
                    Toplam <span class="text-slate-900">@Model.Count()</span> varlık içinden <span class="text-slate-900">1-@Model.Count()</span> arası gösteriliyor
                </p>
                <div class="flex gap-3">
                    <a href="@Url.Action("Index", new { page = Model.PageNumber - 1 })" class="px-3 py-1 border rounded @(Model.HasPreviousPage ? "bg-white text-black" : "bg-gray-200 text-gray-500 pointer-events-none")">
                        Önceki
                    </a>
                    <a href="@Url.Action("Index", new { page = Model.PageNumber + 1 })" class="px-3 py-1 border rounded @(Model.HasNextPage ? "bg-white text-black" : "bg-gray-200 text-gray-500 pointer-events-none")">
                        Sonraki
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
