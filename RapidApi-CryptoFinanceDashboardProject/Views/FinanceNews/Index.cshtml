@model IEnumerable<RapidApi_CryptoFinanceDashboardProject.Models.Datum>

@{
    ViewData["Title"] = "Piyasa Haberleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex-1 overflow-y-auto p-8 space-y-8">
    <div class="mx-auto max-w-7xl space-y-8">

        <div class="space-y-4">
            <div class="flex items-center justify-between px-1">
                <h2 class="text-lg font-bold text-slate-900">Piyasa Haberleri</h2>
                <a class="text-sm font-semibold text-primary hover:text-primary/80 flex items-center gap-1" href="#">
                    Tümünü Gör
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var item in Model)
                    {
                        <div class="rounded-3xl bg-white p-5 shadow-soft border border-slate-100 hover:border-primary/20 transition-all cursor-pointer">
                            <img src="@(!string.IsNullOrEmpty(item.photo_url) ? item.photo_url : "https://bs-uploads.toptal.io/blackfish-uploads/components/blog_post_page/4087184/cover_image/regular_1708x683/Untitled-c7f4c86ddb44556b00a31a37e4219c3d.png")"
                                 class="w-full h-40 object-cover rounded-xl mb-4"
                                 alt="@item.title" />

                            <p class="text-xs font-medium text-slate-500">@item.published_datetime_utc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>

                            <a href="@item.link" target="_blank" class="block mt-2">
                                <p class="font-bold text-slate-900 line-clamp-2" title="@item.title">@item.title</p>
                            </a>

                            <p class="text-sm text-slate-600 mt-2 line-clamp-3">@item.snippet</p>

                            <div class="mt-3 flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    @if (!string.IsNullOrEmpty(item.source_favicon_url))
                                    {
                                        <img src="@item.source_favicon_url" class="w-4 h-4 rounded-full" alt="logo" />
                                    }
                                    <p class="text-xs font-medium text-slate-500 line-clamp-1">
                                        @(item.authors != null && item.authors.Length > 0 ? string.Join(", ", item.authors) : item.source_name)
                                    </p>
                                </div>
                                <span class="px-2 py-1 rounded text-xs font-bold bg-slate-100 text-slate-800 whitespace-nowrap">
                                    @item.source_name
                                </span>
                            </div>
                        </div>
                    }
            </div>
        </div>
    </div>
</div>