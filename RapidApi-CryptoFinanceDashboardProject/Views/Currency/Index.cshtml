@model List<RapidApi_CryptoFinanceDashboardProject.Models.Currency>
@{
    ViewData["Title"] = "Döviz Kurları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex min-h-screen items-center justify-center p-8 -mt-16">
    <div class="mx-auto w-full max-w-2xl space-y-8">

        <div class="space-y-4">
            <div class="flex items-center justify-between px-1">
                <h2 class="text-lg font-bold text-slate-900">Canlı Döviz Kurları</h2>
                <a class="text-sm font-semibold text-primary hover:text-primary/80 flex items-center gap-1" href="#">
                    Piyasa Özeti
                    <span class="material-symbols-outlined text-sm">monitoring</span>
                </a>
            </div>

            <div class="bg-white p-5 rounded-3xl shadow-soft border border-slate-100">
                <form method="get" asp-controller="Currency" asp-action="Index" class="flex flex-col md:flex-row gap-4 items-end">

                    <div class="flex-1 w-full">
                        <label for="bases" class="block text-sm font-semibold text-slate-700 mb-1.5">Ana Birim (Base)</label>
                        <input type="text" id="bases" name="bases" value="" placeholder="Örn: USD, EUR, GBP"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary uppercase font-bold" required>
                    </div>

                    <div class="flex-1 w-full">
                        <label for="target" class="block text-sm font-semibold text-slate-700 mb-1.5">Hedef Birim (Target)</label>
                        <input type="text" id="target" name="target" value="" placeholder="Örn: TRY, JPY, CAD"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary uppercase font-bold" required>
                    </div>

                    <div class="w-full md:w-auto">
                        <button type="submit" class="w-full md:w-auto px-8 py-2.5 bg-slate-900 hover:bg-slate-800 text-white text-sm font-bold rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">currency_exchange</span>
                            Sorgula
                        </button>
                    </div>
                </form>
            </div>

            <div class="grid grid-cols-1 gap-6 mt-4">
                @foreach (var item in Model)
                {
                    <div class="rounded-3xl bg-white p-6 shadow-soft border border-slate-100 hover:border-primary/20 hover:shadow-md transition-all text-center">

                        <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-blue-100">
                            <span class="material-symbols-outlined text-blue-600 text-3xl">payments</span>
                        </div>

                        <p class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-2">
                            @item._base / @item.target
                        </p>

                        <div class="flex justify-center items-baseline gap-1">
                            <span class="text-4xl font-extrabold text-slate-900">@item.rate.ToString("N4")</span>
                        </div>

                        <div class="mt-5 pt-4 border-t border-slate-50 text-xs text-slate-500 font-medium">
                            1 @item._base = @item.rate.ToString("N4") @item.target
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>