@model IEnumerable<RapidApi_CryptoFinanceDashboardProject.Models.Rsi>
@{
    ViewData["Title"] = "RSI Teknik Analizi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex-1 overflow-y-auto p-8 space-y-8">
    <div class="mx-auto max-w-7xl space-y-8">

        <div class="space-y-4">
            <div class="flex items-center justify-between px-1">
                <h2 class="text-lg font-bold text-slate-900">RSI Teknik Analizi</h2>
                <a class="text-sm font-semibold text-primary hover:text-primary/80 flex items-center gap-1" href="#">
                    Grafikte Gör
                    <span class="material-symbols-outlined text-sm">show_chart</span>
                </a>
            </div>

            <div class="bg-white p-5 rounded-3xl shadow-soft border border-slate-100">
                <form method="get" asp-controller="Indicator" asp-action="Index" class="flex flex-col md:flex-row gap-4 items-end">

                    <div class="flex-1 w-full">
                        <label for="symbol" class="block text-sm font-semibold text-slate-700 mb-1.5">Sembol</label>
                        <input type="text" id="symbol" name="symbol" placeholder="Örn: BTCUSDT, ETHUSDT"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary uppercase" required>
                    </div>

                    <div class="flex-1 w-full">
                        <label for="time" class="block text-sm font-semibold text-slate-700 mb-1.5">Zaman Dilimi (Mum Kapanışı)</label>
                        <select id="time" name="time" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary bg-white">
                            <option value="1">1 Dakika</option>
                            <option value="3">3 Dakika</option>
                            <option value="5">5 Dakika</option>
                            <option value="15">15 Dakika</option>
                            <option value="30">30 Dakika</option>
                        </select>
                    </div>

                    <div class="w-full md:w-auto">
                        <button type="submit" class="w-full md:w-auto px-8 py-2.5 bg-slate-900 hover:bg-slate-800 text-white text-sm font-bold rounded-xl transition-all shadow-sm">
                            Verileri Getir
                        </button>
                    </div>
                </form>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
                @foreach (var item in Model.Take(9))
                {
                    string badgeClass = "bg-blue-50 text-blue-800 border-blue-100";
                    string badgeText = "Nötr";

                    if (item.rsi >= 70)
                    {
                        badgeClass = "bg-red-50 text-red-800 border-red-100";
                        badgeText = "Aşırı Alım (Riskli)";
                    }
                    else if (item.rsi <= 30)
                    {
                        badgeClass = "bg-green-50 text-green-800 border-green-100";
                        badgeText = "Aşırı Satım (Fırsat)";
                    }

                    <div class="rounded-3xl bg-white p-5 shadow-soft border border-slate-100 hover:border-primary/20 transition-all cursor-pointer">
                        <div class="flex items-center justify-between gap-2 mb-3">
                            <span class="px-2.5 py-1 rounded-lg text-xs font-bold border @badgeClass">
                                @badgeText
                            </span>
                            <span class="text-xs font-semibold text-text-muted uppercase">RSI (14)</span>
                        </div>

                        <p class="text-xs font-medium text-text-muted">@DateTimeOffset.FromUnixTimeMilliseconds(item.time).LocalDateTime.ToString("dd MMMM yyyy, HH:mm")</p>

                        <div class="mt-4 flex justify-between items-center border-t border-slate-50 pt-3">
                            <div>
                                <p class="text-xs font-medium text-slate-500">RSI Değeri</p>
                                <p class="font-bold text-lg text-slate-900">@item.rsi.ToString("0.00")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-medium text-slate-500">Kapanış Fiyatı</p>
                                <p class="font-bold text-lg text-slate-900">$@item.close.ToString("N2")</p>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>